# Auto detect text files and normalize line endings
* text=auto

# JavaScript / HTML / CSS / JSON
*.js text eol=lf
*.html text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf

# Shell scripts
*.sh text eol=lf

# Docker
Dockerfile text eol=lf
docker-compose.yml text eol=lf

# Lock file (generated, treat as binary to avoid merge conflicts)
package-lock.json binary
